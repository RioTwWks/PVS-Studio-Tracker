# === PVS-Studio Tracker Configuration ===

# База данных (по умолчанию SQLite)
DATABASE_URL=sqlite:///./pvs_tracker.db

# Секретные ключи (ОБЯЗАТЕЛЬНО замените на свои в продакшене!)
SECRET_KEY=token_here
JWT_SECRET_KEY=token_here

# Алгоритм и время жизни токена
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Вебхуки (опционально)
WEBHOOK_URL=
WEBHOOK_SECRET=

# Режим окружения (для отладки)
ENVIRONMENT=development