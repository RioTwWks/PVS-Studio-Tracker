# === PVS-Studio Tracker ===
# Copy to .env and adjust for production.

# Database
DATABASE_URL=sqlite:///./pvs_tracker.db

# Session cookies (UI)
SECRET_KEY=change-me-to-secure-random-string

# API v2 JWT (defaults to SECRET_KEY if unset)
JWT_SECRET_KEY=

# Webhooks (optional)
WEBHOOK_URL=
WEBHOOK_SECRET=

# Email notifications (optional, for API upload subscribers)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
APP_BASE_URL=http://localhost:8080

# Git / code viewer caches (optional)
GIT_CACHE_DIR=
SNAPSHOTS_DIR=
GIT_CACHE_TTL_MINUTES=60
GIT_TIMEOUT_SECONDS=120

# Note: JWT_ALGORITHM and ACCESS_TOKEN_EXPIRE_MINUTES in older docs —
# token expiry is currently set in auth_service.py (24h) unless code is updated.
