# === PVS-Studio Tracker ===
# Copy to .env and adjust for production.

# Database
DATABASE_URL=sqlite:///./pvs_tracker.db

# Session cookies (UI)
SECRET_KEY=change-me-to-secure-random-string

# API v2 JWT (defaults to SECRET_KEY if unset)
JWT_SECRET_KEY=

# Webhooks (optional, outbound)
WEBHOOK_URL=
WEBHOOK_SECRET=

# Inbound TFS/Git webhooks + Jenkins CI
WEBHOOK_USERNAME=builder
WEBHOOK_PASSWORD=password
JENKINS_URL=https://jenkins.example.com
JENKINS_JOB_NAME=PVS_Tracker_Analysis
JENKINS_USERNAME=admin
JENKINS_TOKEN=jenkins_token
TFS_BASE_URL=http://tfs.example.com/tfs/Collection

# Jira sync after upload (optional)
JIRA_URL=https://jira.example.com
JIRA_USERNAME=admin
JIRA_PASSWORD=password
JIRA_VERIFY_CERT=
JIRA_FINGERPRINT_FIELD=customfield_12205

# Admin IP/hostname for CI manage UI (analyze/delete)
ADMIN_IPS=127.0.0.1
ADMIN_HOSTNAMES=localhost
CI_TEMP_DIR=temp_repos

# Email notifications (optional, for API upload subscribers)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
APP_BASE_URL=http://localhost:8080

# Git / code viewer caches (optional)
GIT_CACHE_DIR=
SNAPSHOTS_DIR=
GIT_CACHE_TTL_MINUTES=60
GIT_TIMEOUT_SECONDS=120

# Note: JWT_ALGORITHM and ACCESS_TOKEN_EXPIRE_MINUTES in older docs —
# token expiry is currently set in auth_service.py (24h) unless code is updated.
