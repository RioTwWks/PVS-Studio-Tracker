# === PVS-Studio Tracker — Docker Compose (Windows containers) ===
# Скопируйте в deploy/docker-compose-windows/.env

# Версия базового образа Windows (должна совпадать с хостом: ltsc2019 / ltsc2022)
WINDOWS_VERSION=ltsc2019-amd64

# --- PostgreSQL на хосте Windows (режим по умолчанию) ---
# host.docker.internal — DNS Docker Engine для доступа к службам на хосте.
DATABASE_URL=postgresql+psycopg2://pvs:change-me@host.docker.internal:5432/pvs_tracker

# --- PostgreSQL в контейнере (docker-compose.postgres.yml) ---
# Пароль для роли pvs в контейнере postgres (override подставит DATABASE_URL автоматически).
POSTGRES_PASSWORD=pvs

# Session cookies (UI)
SECRET_KEY=change-me-to-secure-random-string
SESSION_HTTPS_ONLY=false
SESSION_SAME_SITE=lax

# LDAP authentication (optional)
LDAP_ENABLED=false
LDAP_URL=ldap://domain.company.ru:389
LDAP_USE_TLS=false
LDAP_AUTH_METHOD=simple
LDAP_USER_DOMAIN=company.ru
LDAP_BASE_DN=DC=company,DC=ru
LDAP_BIND_DN=email@company.ru
LDAP_BIND_PASSWORD=password
LDAP_USER_BASE_DN=DC=company,DC=ru
LDAP_USER_REQUEST=(&(objectCategory=Person)(sAMAccountName={login}))
LDAP_USER_REAL_NAME_ATTRIBUTE=displayName
LDAP_USER_EMAIL_ATTRIBUTE=mail
LDAP_GROUP_BASE_DN=DC=company,DC=ru
LDAP_GROUP_REQUEST=(&(objectCategory=Group)(member={dn}))
LDAP_FOLLOW_REFERRALS=true
LDAP_DOWNCASE=true
LDAP_BIND_TIMEOUT=10

JWT_SECRET_KEY=

WEBHOOK_URL=
WEBHOOK_SECRET=

WEBHOOK_USERNAME=builder
WEBHOOK_PASSWORD=password
JENKINS_URL=https://jenkins.example.com
JENKINS_JOB_NAME=PVS_Tracker_Analysis
JENKINS_USERNAME=admin
JENKINS_TOKEN=jenkins_token
TFS_BASE_URL=http://tfs.example.com/tfs/Collection

JIRA_URL=https://jira.example.com
JIRA_USERNAME=admin
JIRA_PASSWORD=password
JIRA_VERIFY_CERT=
JIRA_FINGERPRINT_FIELD=customfield_12205

ADMIN_IPS=127.0.0.1
ADMIN_HOSTNAMES=localhost
CI_TEMP_DIR=temp_repos

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
APP_BASE_URL=http://localhost:8080

GIT_CACHE_DIR=
SNAPSHOTS_DIR=
GIT_CACHE_TTL_MINUTES=60
GIT_TIMEOUT_SECONDS=120

# В compose-режиме воркеры — отдельные контейнеры (переопределяется в docker-compose.yml).
REST_QUEUE_MODE=external
REST_QUEUE_POLL_INTERVAL=1.0
