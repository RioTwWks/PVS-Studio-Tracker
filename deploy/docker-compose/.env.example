# === PVS-Studio Tracker — Docker Compose (Linux) ===
# cp .env.example .env

SECRET_KEY=change-me-to-secure-random-string
SESSION_HTTPS_ONLY=false
SESSION_SAME_SITE=lax

# Корпоративный proxy.
# ВАЖНО: для docker pull (postgres, nginx, python) нужен proxy в daemon.json — см. README.
# Эти переменные идут в build (pip/apt) и в running-контейнеры app/worker.
# HTTP_PROXY=http://proxy.corp.local:8080
# HTTPS_PROXY=http://proxy.corp.local:8080
# NO_PROXY=localhost,127.0.0.1,.corp.local,postgres

WEBHOOK_URL=
WEBHOOK_SECRET=
